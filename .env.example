# smith-automation — Environment Variables
#
# Copy this file to .env and fill in your keys:
#   cp .env.example .env
#
# The examples read keys via std::env::var() at runtime.
# Dotenv (.env file) loading is not yet wired — for now set them
# in your shell or use your terminal's native env management.

# OpenAI / OpenAI-compatible providers (OpenRouter, vLLM, OpenCode, etc.)
OPENAI_API_KEY=sk-your-key-here

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here
